import os
from cryptography.hazmat.primitives.asymmetric import rsa
from cryptography.hazmat.primitives import serialization

def generer_cles_rsa(nom_utilisateur):
    cle_privee = rsa.generate_private_key(
        public_exponent=65537,
        key_size=2048
    )

    cle_publique = cle_privee.public_key()

    pem_privee = cle_privee.private_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PrivateFormat.PKCS8,
        encryption_algorithm=serialization.NoEncryption()
    )

    pem_publique = cle_publique.public_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PublicFormat.SubjectPublicKeyInfo
    )

    dossier = f"cles/{nom_utilisateur}"
    os.makedirs(dossier, exist_ok=True)

    with open(f"{dossier}/cle_privee.pem", "wb") as f:
        f.write(pem_privee)

    return pem_publique.decode()
